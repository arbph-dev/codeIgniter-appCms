## ModelWorkbench.js - extends WorkbenchBase
```js
/**
 * ModelWorkbench.js
 * Workbench spécialisé dans la visualisation et manipulation de modèles 3D
 */

import { WorkbenchBase } from '../core/WorkbenchBase.js';
import { LoaderFactory } from '../io/LoaderFactory.js';
import { GeometryAnalysis } from '../services/GeometryAnalysis.js';

import { Toolbar } from '../ui/Toolbar.js';
import { ModelTreeView } from '../ui/ModelTreeView.js';
import { TreeView } from '../ui/TreeView.js';
import { Inspector } from '../ui/Inspector.js';
import { StatusBar } from '../ui/StatusBar.js';

import { MODEL_LIST } from '../data/modelList.js';

export class ModelWorkbench extends WorkbenchBase
{
    constructor({ container })
    {
        super({ 
            container, 
            workbenchType: 'model' 
        });

        this.currentModel = null;      // ModelDescriptor actuel
        this.currentRoot  = null;      // THREE.Object3D racine du modèle chargé
    }

    // Surcharge de la création des composants UI
    _createUIComponents()
    {
        // Toolbar
        this.toolbar = new Toolbar({
            container    : this._toolbarEl,
            sceneManager : this.sceneManager,
            onClearScene : () => this.clear()
        });

        // Catalogue des modèles (gauche haut)
        this.modelTreeView = new ModelTreeView({
            container : this._modelTreeEl || this._leftEl,
            models    : MODEL_LIST,
            onSelect  : (model) => this.loadModelDescriptor(model)
        });

        // Arbre de hiérarchie du modèle chargé (gauche bas)
        this.treeView = new TreeView({
            container : this._treeviewEl,
            onSelect  : (node) => this.emit('selectionChanged', node)
        });

        // Panneau d'inspection
        this.inspector = new Inspector({
            container : this._inspectorEl
        });

        // Barre de statut
        this.statusBar = new StatusBar({
            container : this._statusbarEl
        });
    }

    // ─── Chargement de modèle ─────────────────────────────────────

    async loadModelDescriptor(model)
    {
        this.clearCurrentModel();
        
        this.currentModel = model;
        const result = await this.loadModel(model);
        
        this.onModelLoaded(result);
        this.modelTreeView?.markAsLoaded?.(model.id);
    }

    async loadModel(model)
    {
        const result = await LoaderFactory.load({
            path       : model.resource.path,
            mtl        : model.resource.mtl,
            targetSize : model.transform.targetSize,
        });

        this.currentRoot = result.obj;
        this.sceneManager.scene.add(result.obj);

        if (result.mixer)
        {
            this.sceneManager.addMixer(result.mixer);
        }

        this.analyze(result);

        return result;
    }

    analyze(result)
    {
        const report = GeometryAnalysis.analyze(result);

        this.statusBar.render(report.global);
        this.treeView.render(result.obj);
        this.inspector.showGlobal(report);

        return report;
    }

    // ─── Nettoyage ───────────────────────────────────────────────

    clearCurrentModel()
    {
        if (this.currentRoot)
        {
            this.sceneManager.scene.remove(this.currentRoot);

            // Nettoyage mémoire Three.js
            this.currentRoot.traverse((child) => {
                if (child.geometry) child.geometry.dispose();

                if (child.material) {
                    if (Array.isArray(child.material)) {
                        child.material.forEach(mat => mat.dispose?.());
                    } else {
                        child.material.dispose?.();
                    }
                }
            });

            this.currentRoot = null;
        }

        this.treeView?.clear?.();
        this.inspector?._empty?.();
        this.statusBar?.clear?.();
    }

    clear()
    {
        this.clearCurrentModel();
        this.currentModel = null;
        this.modelTreeView?.clearSelection?.();
        super.clear();                    // Appel à la méthode de la classe parent
    }

    // ─── Hooks ───────────────────────────────────────────────────

    onInitialized()
    {
        this.enableAutoResize();
        console.log('%cModelWorkbench initialized', 'color: #0f0; font-weight: bold');
    }

    onModelLoaded(result)
    {
        console.log('Model loaded:', this.currentModel?.name);
        // Tu peux émettre un événement si besoin
        this.emit('modelLoaded', { model: this.currentModel, result });
    }

    // ─── Destruction ─────────────────────────────────────────────

    destroy()
    {
        this.clearCurrentModel();
        super.destroy();                  // Appel à la destruction de la classe parent
    }
}
```






